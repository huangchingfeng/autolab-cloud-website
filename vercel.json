{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "dist/public",
  "functions": {
    "api/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/claude-code-manual/?", "dest": "/claude-code-manual/index.html" },
    { "src": "/claude-code-manual/(.*)", "dest": "/claude-code-manual/$1" },
    { "src": "/gifts/(.*)", "dest": "/gifts/$1" },
    { "src": "/jci-ai-tools/?", "dest": "/jci-ai-tools/index.html" },
    { "src": "/jci-ai-tools/(.*)", "dest": "/jci-ai-tools/$1" },
    { "src": "/20260331-hochun-ai/?", "dest": "/20260331-hochun-ai/index.html" },
    { "src": "/20260331-hochun-ai/(.*)", "dest": "/20260331-hochun-ai/$1" },
    { "src": "/api/test", "dest": "/api/test" },
    { "src": "/api/(.*)", "dest": "/api" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
